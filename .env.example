PORT=8090
APP_BASE_URL=http://localhost:8090
APP_SECRET=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGINS=http://localhost:8090
INITIAL_ADMIN_EMAIL=owner@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-unique-password

# Supabase project settings. Keep the service-role key on the API server only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_KEY

# Legacy fallback only. Prefer SUPABASE_SECRET_KEY for new projects.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVICE_ROLE_KEY

# Stripe server-side settings.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MERCHANT_IDENTIFIER=merchant.com.yomiyoga.studio

# Deployment CLI values. Do not expose server secrets through EXPO_PUBLIC_*.
SUPABASE_ACCESS_TOKEN=
EXPO_TOKEN=
EXPO_PUBLIC_API_BASE_URL=https://YOUR_API_HOST/api/v1
YOMI_API_BASE_URL=https://YOUR_API_HOST/api/v1
