{
  "expo": {
    "name": "Yomi Yoga",
    "slug": "yomi-yoga",
    "scheme": "yomiyoga",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yomiyoga.studio",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is used by staff and admins to scan booking check-in QR codes.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used by admins to upload coach, content, and product images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F6F2"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-camera",
      "expo-image-picker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.yomiyoga.studio",
          "enableGooglePay": false
        }
      ],
      "expo-font"
    ],
    "extra": {}
  }
}
