{
  "expo": {
    "name": "Yomi Yoga",
    "slug": "yomi-yoga",
    "scheme": "yomiyoga",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yomiyoga.studio",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is used by staff and admins to scan booking check-in QR codes.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used by admins to upload coach, content, and product images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F6F2"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-camera",
      "expo-image-picker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.yomiyoga.studio",
          "enableGooglePay": false
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75b391af-50bd-41a9-967b-2736a6d09905"
      }
    },
    "owner": "yogayoga"
  }
}
